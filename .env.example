# Embedding Service
EMBEDDING_HOST=0.0.0.0
EMBEDDING_PORT=8001
EMBEDDING_MODEL_NAME=japanese-splade-mock
EMBEDDING_MAX_TOKENS_PER_TEXT=64

# Retrieval Service
RETRIEVAL_HOST=0.0.0.0
RETRIEVAL_PORT=8000
RETRIEVAL_EMBEDDING_API_BASE_URL=http://localhost:8001
RETRIEVAL_LLM_GENERATION_API_BASE_URL=http://localhost:8002
RETRIEVAL_DEFAULT_TOP_K=5
RETRIEVAL_DEFAULT_SCORE_THRESHOLD=0.20
RETRIEVAL_FALLBACK_MESSAGE=該当情報が見つからないため、回答できませんでした。
RETRIEVAL_LLM_TIMEOUT_SECONDS=30
RETRIEVAL_LLM_RETRY_COUNT=2
RETRIEVAL_LLM_MAX_TOKENS=512

# LLM Generation Service
LLM_HOST=0.0.0.0
LLM_PORT=8002
LLM_MODE=mock
LLM_OLLAMA_BASE_URL=http://localhost:11434
LLM_OLLAMA_MODEL=gemma3
LLM_OLLAMA_TIMEOUT_SECONDS=30
